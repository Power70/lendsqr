# Copy to .env and fill in values. The app refuses to boot if required values
# are missing or invalid (validated by a zod schema in src/config/env.ts).

NODE_ENV=development
PORT=3000

# MySQL — matches docker-compose.yml defaults for local development
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=demo_credit
DB_PASSWORD=change_me
DB_NAME=demo_credit
DB_POOL_MIN=2
DB_POOL_MAX=10
# set true for managed MySQL providers that require TLS
DB_SSL=false
# base64-encoded CA certificate (PEM) — needed when the provider (e.g. Aiven)
# signs with a private CA:  base64 -w0 ca.pem
# DB_SSL_CA=

LOG_LEVEL=info

# Auth (faux JWT)
JWT_SECRET=<random string, minimum 32 characters>
JWT_EXPIRES_IN=24h

# Adjutor Karma blacklist — key from https://app.adjutor.io
ADJUTOR_BASE_URL=https://adjutor.lendsqr.com/v2
ADJUTOR_API_KEY=<from your Adjutor dashboard>
ADJUTOR_TIMEOUT_MS=5000

# Rate limiting (per IP, per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
